#!/usr/bin/env bash
#
# Fast pre-push gate: typecheck + lint + unit tests. No browser / no e2e.
#
# Enabled automatically via the `prepare` script in package.json
# (git config core.hooksPath .githooks). To skip a one-off push: git push --no-verify
#
set -euo pipefail

echo "[pre-push] typecheck…"
npm run typecheck

echo "[pre-push] lint…"
npm run lint

echo "[pre-push] unit tests…"
npm test

echo "[pre-push] ok"

{
  "name": "stop-yapping-bro",
  "version": "1.2.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "icons": "node scripts/generate-icons.mjs",
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "package": "npm run build && node scripts/package-extension.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/chrome": "^0.0.287",
    "archiver": "^7.0.1",
    "happy-dom": "^20.9.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.21",
    "vite-plugin-web-extension": "^4.3.1",
    "vitest": "^2.0.5"
  }
}

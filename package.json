{
  "name": "stop-yapping-bro",
  "version": "1.2.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "icons": "node scripts/generate-icons.mjs",
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "postinstall": "wxt prepare",
    "package": "wxt zip",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "typecheck": "wxt prepare && tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/chrome": "^0.0.287",
    "happy-dom": "^20.9.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.21",
    "vitest": "^2.0.5",
    "wxt": "0.20.26"
  }
}

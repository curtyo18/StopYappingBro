# Supply-chain hardening defaults.
# min-release-age requires a recent npm (verify with `npm config get min-release-age` — no warning means supported).

# Quarantine: refuse to install package versions released fewer than 3 days ago.
# Most npm worms (shai-hulud, etc.) are caught and unpublished within 24-48h.
# Cannot be combined with the `before` config.
min-release-age=3

# Block lifecycle scripts (postinstall, preinstall, etc.) - the primary
# execution vector for compromised packages. To rebuild native deps:
#   npm rebuild sharp esbuild better-sqlite3
ignore-scripts=true

# Pin exact versions in package.json - no ^ or ~ ranges. A pinned lockfile
# is the line of defense; loose ranges in package.json undermine it on
# fresh installs.
save-exact=true

# Lockfile + audit.
package-lock=true
audit-level=high
fund=false

# Pin the registry so a stray env var or workspace .npmrc can't redirect
# installs to a hostile mirror.
registry=https://registry.npmjs.org/

# Refuse to install if the project's "engines" field doesn't match.
engine-strict=true
